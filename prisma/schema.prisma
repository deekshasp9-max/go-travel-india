generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  avatar    String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rides            Ride[]
  savedItineraries SavedItinerary[]
  bookings         Booking[]
}

model Ride {
  id            String   @id @default(cuid())
  userId        String?
  rideType      String
  pickup        String
  destination   String
  pickupLat     Float
  pickupLng     Float
  destLat       Float
  destLng       Float
  distance      Float
  fare          Float
  status        String   @default("completed")
  paymentMethod String   @default("")
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model SOSAlert {
  id        String   @id @default(cuid())
  rideId    String?
  latitude  Float
  longitude Float
  message   String   @default("SOS Alert triggered!")
  createdAt DateTime @default(now())
}

model SavedItinerary {
  id        String   @id @default(cuid())
  userId    String?
  city      String
  title     String
  days      Int
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Booking {
  id            String   @id @default(cuid())
  userId        String?
  itineraryId   String
  city          String
  state         String
  title         String
  image         String
  duration      String
  budget        String
  bestSeason    String
  rating        Float
  travelDate    String
  travelers     Int
  totalPrice    Float
  guestName     String
  guestEmail    String
  guestPhone    String
  paymentMethod String   @default("")
  status        String   @default("confirmed")
  paymentStatus String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}
